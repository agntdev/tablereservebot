[
  {
    "name": "cal:pick rejects past-date callback",
    "steps": [
      {
        "send": { "callback": "cal:pick:2020-01-01" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Date **2020-01-01** is in the past. Please select today or a future date."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/book rejects a date in the past via calendar flow",
    "steps": [
      {
        "send": { "text": "/book 2020-01-01 19:00 4" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Date cannot be in the past. Please choose today or a future date."
            }
          }
        ]
      }
    ]
  }
]