[
  {
    "name": "slot book with empty guest name is rejected",
    "steps": [
      {
        "send": { "text": "/calendar" },
        "expect": [
          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "callback": "cal:pick:2026-07-15" },
        "expect": [
          { "method": "editMessageText" },
          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "callback": "party:1" },
        "expect": [
          { "method": "editMessageText" },
          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "callback": "slot:pick:09:00" },
        "expect": [
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "slot:book" },
        "expect": [
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "text": "  " },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Please enter a valid guest name."
            }
          }
        ]
      }
    ]
  }
]
