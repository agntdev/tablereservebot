[
  {
    "name": "/remind by admin checks bookings and reports results",
    "steps": [
      {
        "send": { "text": "/remind", "userId": 777 },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "📋 How to Reserve", "callback_data": "menu:about" }],
                  [{ "text": "🛟 Need Assistance?", "callback_data": "menu:help" }],
                  [{ "text": "⚙️ Settings", "callback_data": "menu:settings" }]
                ]
              }
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/remind by non-admin shows access denied",
    "steps": [
      {
        "send": { "text": "/remind", "userId": 999 },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Access denied. You are not an admin."
            }
          }
        ]
      }
    ]
  }
]
