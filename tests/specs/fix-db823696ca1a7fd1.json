  {
    "name": "cal:pick accepts same-month date and prompts for party size",
    "steps": [
      {
        "send": { "text": "/calendar" },
        "expect": [
          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "callback": "cal:pick:2026-06-25" },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": { "text": "✅ You selected **2026-06-25**." }
          },
          {
            "method": "sendMessage",
            "payload": {
              "text": "✅ Date: 2026-06-25\n\nHow many guests? Pick a quick option or type a number."
            }
          }
        ]
      }
