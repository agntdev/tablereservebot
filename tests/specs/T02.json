[
  {
    "name": "/start replies with welcome and an inline keyboard main menu",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Welcome! I am the AGNTDEV bot — your assistant for Telegram bot development.\n\nUse the menu below to get started:",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "📋 About", "callback_data": "menu:about" }],
                  [{ "text": "🛟 Help", "callback_data": "menu:help" }],
                  [{ "text": "⚙️ Settings", "callback_data": "menu:settings" }]
                ]
              }
            }
          }
        ]
      }
    ]
  },
  {
    "name": "menu:about callback replies with about text and the menu",
    "steps": [
      {
        "send": { "callback": "menu:about" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "I am the AGNTDEV bot, built with the grammY framework and the AGNTDEV bot toolkit. I help you build, test, and deploy Telegram bots.",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "📋 About", "callback_data": "menu:about" }],
                  [{ "text": "🛟 Help", "callback_data": "menu:help" }],
                  [{ "text": "⚙️ Settings", "callback_data": "menu:settings" }]
                ]
              }
            }
          }
        ]
      }
    ]
  },
  {
    "name": "menu:help callback replies with help text and the menu",
    "steps": [
      {
        "send": { "callback": "menu:help" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Available commands:\n/start — Show the main menu\n\nUse the menu buttons below to navigate.",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "📋 About", "callback_data": "menu:about" }],
                  [{ "text": "🛟 Help", "callback_data": "menu:help" }],
                  [{ "text": "⚙️ Settings", "callback_data": "menu:settings" }]
                ]
              }
            }
          }
        ]
      }
    ]
  },
  {
    "name": "menu:settings callback replies with settings text and the menu",
    "steps": [
      {
        "send": { "callback": "menu:settings" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Settings are managed through the bot's environment and persistent storage. Use the menu below to navigate.",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "📋 About", "callback_data": "menu:about" }],
                  [{ "text": "🛟 Help", "callback_data": "menu:help" }],
                  [{ "text": "⚙️ Settings", "callback_data": "menu:settings" }]
                ]
              }
            }
          }
        ]
      }
    ]
  },
  {
    "name": "non-command text still replies with a prompt",
    "steps": [
      {
        "send": { "text": "hello" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Use /start to get started." } }
        ]
      }
    ]
  }
]
