[
  {
    "name": "non-command text replies with a prompt",
    "steps": [
      {
        "send": { "text": "hello" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Use /start to get started." } }
        ]
      }
    ]
  },
  {
    "name": "/start replies with a welcome",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Welcome! I am ready to help." } }
        ]
      }
    ]
  }
]
