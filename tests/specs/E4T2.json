[
  {
    "name": "/upcoming shows upcoming bookings for the next 7 days with main menu",
    "steps": [
      {
        "send": { "text": "/upcoming" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "📋 How to Reserve", "callback_data": "menu:about" }],
                  [{ "text": "🛟 Need Assistance?", "callback_data": "menu:help" }],
                  [{ "text": "⚙️ Settings", "callback_data": "menu:settings" }]
                ]
              }
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/upcoming with explicit days shows bookings with main menu",
    "steps": [
      {
        "send": { "text": "/upcoming 30" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "📋 How to Reserve", "callback_data": "menu:about" }],
                  [{ "text": "🛟 Need Assistance?", "callback_data": "menu:help" }],
                  [{ "text": "⚙️ Settings", "callback_data": "menu:settings" }]
                ]
              }
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/upcoming with invalid days shows error message",
    "steps": [
      {
        "send": { "text": "/upcoming 0" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Days must be a positive number (1–365). Example: /upcoming 7"
            }
          }
        ]
      }
    ]
  }
]
