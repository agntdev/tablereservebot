                    { "text": "17", "callback_data": "cal:pick:2026-06-17" },
                    { "text": "18", "callback_data": "cal:pick:2026-06-18" },
                    { "text": "19", "callback_data": "cal:pick:2026-06-19" },
                    { "text": "20", "callback_data": "cal:pick:2026-06-20" },
                    { "text": "21", "callback_data": "cal:pick:2026-06-21" }
                  ],
                  [
                    { "text": "22", "callback_data": "cal:pick:2026-06-22" },
                    { "text": "23", "callback_data": "cal:pick:2026-06-23" },
