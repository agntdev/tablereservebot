                    { "text": "30", "callback_data": "cal:pick:2026-06-30" },
                    { "text": " ", "callback_data": "cal:ignore" },
                    { "text": " ", "callback_data": "cal:ignore" },
                    { "text": " ", "callback_data": "cal:ignore" },
                    { "text": " ", "callback_data": "cal:ignore" },
                    { "text": " ", "callback_data": "cal:ignore" }
                  ],
                  [
                    { "text": "◀ Prev", "callback_data": "cal:nav:2026:4" },
                    { "text": "Next ▶", "callback_data": "cal:nav:2026:6" }
                  ]
                ]
              }
            }
          }
        ]
      }
    ]
  },
  {
    "name": "calendar navigation to next month shows July 2026",
    "steps": [
      {
        "send": { "text": "/calendar" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "📅 June 2026\nSelect a date:"
            }
          }
        ]
      },
      {
        "send": { "callback": "cal:nav:2026:6" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "📅 July 2026\nSelect a date:"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "date pick confirms selection",
    "steps": [
      {
        "send": { "text": "/calendar" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "📅 June 2026\nSelect a date:"
            }
          }
        ]
      },
      {
        "send": { "callback": "cal:pick:2026-06-20" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "✅ You selected **2026-06-20**."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "cal:ignore callback is handled silently",
    "steps": [
      {
        "send": { "text": "/calendar" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "📅 June 2026\nSelect a date:"
            }
          }
        ]
      },
      {
        "send": { "callback": "cal:ignore" },
        "expect": []
      }
    ]
  }
]
