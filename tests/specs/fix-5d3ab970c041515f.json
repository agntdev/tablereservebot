[
  {
    "name": "typed party size shows available slots when storage is present",
    "steps": [
      {
        "send": { "text": "/calendar" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "📅 June 2026\nSelect a date:"
            }
          }
        ]
      },
      {
        "send": { "callback": "cal:pick:2026-06-25" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "✅ You selected **2026-06-25**."
            }
          },
          {
            "method": "sendMessage",
            "payload": {
              "text": "✅ Date: 2026-06-25\n\nHow many guests? Pick a quick option or type a number."
            }
          }
        ]
      },
      {
        "send": { "callback": "party:type" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Type the number of guests (1–99):"
            }
          }
        ]
      },
      {
        "send": { "text": "3" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "✅ Date: 2026-06-25\nGuests: 3"
            }
          },
          {
            "method": "sendMessage"
          }
        ]
      }
    ]
  }
]