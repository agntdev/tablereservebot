[
  {
    "name": "reschedule: changing date and party size mid-flow uses new party size for booking",
    "steps": [
      {
        "send": { "text": "/reschedule REF-TESTOWN" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "✅ Booking REF-TESTOWN has been released.\n\nShowing available time slots for **2026-06-20** (2 guests):"
            }
          },
          {
            "method": "sendMessage",
            "payload": {
              "text": "✅ Date: 2026-06-20\nGuests: 2\n\n47 time slots available. Pick a time:",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "09:00–10:30", "callback_data": "slot:pick:09:00" }],
                  [{ "text": "09:15–10:45", "callback_data": "slot:pick:09:15" }],
                  [{ "text": "09:30–11:00", "callback_data": "slot:pick:09:30" }],
                  [{ "text": "09:45–11:15", "callback_data": "slot:pick:09:45" }],
                  [{ "text": "10:00–11:30", "callback_data": "slot:pick:10:00" }],
                  [{ "text": "10:15–11:45", "callback_data": "slot:pick:10:15" }],
                  [{ "text": "Next »", "callback_data": "slot:page:1" }]
                ]
              }
            }
          }
        ]
      },
      {
        "send": { "callback": "cal:pick:2026-07-01" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "✅ You selected **2026-07-01**."
            }
          },
          {
            "method": "sendMessage",
            "payload": {
              "text": "✅ Date: 2026-07-01\n\nHow many guests? Pick a quick option or type a number.",
              "reply_markup": {
                "inline_keyboard": [
                  [
                    { "text": "2", "callback_data": "party:2" },
                    { "text": "4", "callback_data": "party:4" }
                  ],
                  [
                    { "text": "6", "callback_data": "party:6" },
                    { "text": "8", "callback_data": "party:8" }
                  ],
                  [
                    { "text": "Type a number", "callback_data": "party:type" }
                  ]
                ]
              }
            }
          }
        ]
      },
      {
        "send": { "callback": "party:4" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "✅ Date: 2026-07-01\nGuests: 4"
            }
          },
          {
            "method": "sendMessage"
          }
        ]
      },
      {
        "send": { "callback": "slot:pick:09:00" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "📋 How to Reserve", "callback_data": "menu:about" }],
                  [{ "text": "🛟 Need Assistance?", "callback_data": "menu:help" }],
                  [{ "text": "⚙️ Settings", "callback_data": "menu:settings" }]
                ]
              }
            }
          }
        ]
      }
    ]
  }
]
