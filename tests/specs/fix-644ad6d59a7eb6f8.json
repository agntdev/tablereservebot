[
  {
    "name": "/book interactive booking with skip phone completes booking",
    "steps": [
      {
        "send": { "text": "/book 2026-06-25 19:00 3" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Please enter the guest name for the reservation:"
            }
          }
        ]
      },
      {
        "send": { "text": "Bob" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Please enter a contact phone number, or skip:"
            }
          }
        ]
      },
      {
        "send": { "callback": "guest:skip_phone" },
        "expect": [
          { "method": "sendMessage" }
        ]
      }
    ]
  },
  {
    "name": "/book interactive booking with phone entry completes booking",
    "steps": [
      {
        "send": { "text": "/book 2026-06-25 19:00 4" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Please enter the guest name for the reservation:"
            }
          }
        ]
      },
      {
        "send": { "text": "Alice" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Please enter a contact phone number, or skip:"
            }
          }
        ]
      },
      {
        "send": { "text": "+15551234567" },
        "expect": [
          { "method": "sendMessage" }
        ]
      }
    ]
  }
]
